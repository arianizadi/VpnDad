{
  "version": 1,
  "name": "Example MasterDNS",
  "protocol": "masterdns",
  "domain": "dns-tunnel.example.com",
  "domains": ["dns-tunnel.example.com"],
  "expectedExitIP": "203.0.113.20",
  "resolvers": [
    {
      "type": "udp",
      "address": "203.0.113.10:53"
    }
  ],
  "masterdns": {
    "runtimeMode": "nativePacket",
    "clientConfig": {
      "PROTOCOL_TYPE": "TCP",
      "DOMAINS": ["dns-tunnel.example.com"],
      "LOCAL_DNS_ENABLED": true,
      "IOS_FORCE_HEV_SOCKS": false,
      "DATA_ENCRYPTION_METHOD": 5,
      "ENCRYPTION_KEY": "REPLACE_WITH_SHARED_MASTERDNS_KEY",
      "BASE_ENCODE_DATA": false,
      "UPLOAD_COMPRESSION_TYPE": 0,
      "DOWNLOAD_COMPRESSION_TYPE": 0,
      "MIN_UPLOAD_MTU": 38,
      "MAX_UPLOAD_MTU": 150,
      "MIN_DOWNLOAD_MTU": 100,
      "MAX_DOWNLOAD_MTU": 500,
      "RESOLVER_BALANCING_STRATEGY": 2,
      "PACKET_DUPLICATION_COUNT": 2,
      "SETUP_PACKET_DUPLICATION_COUNT": 2,
      "RX_TX_WORKERS": 4,
      "MAX_PACKETS_PER_BATCH": 8,
      "LOG_LEVEL": "INFO"
    }
  }
}
