{
  "version": 1,
  "name": "Example MasterDNS Custom FEC",
  "protocol": "masterdns",
  "domain": "fec-tunnel.example.com",
  "expectedExitIP": "203.0.113.30",
  "resolvers": [
    {
      "type": "udp",
      "address": "203.0.113.11:53"
    }
  ],
